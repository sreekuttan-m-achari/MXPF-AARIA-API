CURSOR_API_KEY=cursor_api_key_here

# Optional: agent working directory (defaults to server cwd)
# AARIA_AGENT_CWD=/home/you/WORKS/AARIA/MXPF-AARIA-API

# Persona: copy SOUL.sample.md → SOUL.md, USER.sample.md → USER.md
# AGENT_SOUL_PATH=/path/to/SOUL.md
# AGENT_USER_PATH=/path/to/USER.md

# Optional: agent state directory (auto-used on Node < 22.13 without node:sqlite)
# AARIA_AGENT_STORE_DIR=/home/you/.aria-agent-store

# Persisted Cursor agent session id (resume on restart; default under SDK state root)
# AARIA_SESSION_DIR=/home/you/.aria-agent-session

# AARIA_MCP_ENABLED=0
# MCP_CONFIG_PATH=.cursor/mcp.json
# CURSOR_SDK_MCP_MODE=file
# Home Assistant HTTP MCP (optional; used in Docker or when set in mcp.json):
# HA_MCP_HTTP_URL=http://homeassistant.local:8123/api/mcp
# HA_API_ACCESS_TOKEN=your_long_lived_token
# HA_BASE_URL=http://homeassistant.local:8123

# WebSocket + HTTP (default http://127.0.0.1:8788)
# AARIA_WS_HOST=127.0.0.1
# AARIA_WS_PORT=8788
# AARIA_API_URL=http://127.0.0.1:8788
# AARIA_SYSTEMD_SERVICE=aria-api.service
# AARIA_LAUNCHD_LABEL=com.aaria.api

# Debug: log conversations to stderr and .aria-conversations.ndjson
# AARIA_DEBUG=1
# AARIA_DEBUG_STREAM=1
# AARIA_DEBUG_LOG=/path/to/conversations.ndjson

# Learn loop (Hermes-style post-turn review → MEMORY.md / USER.md)
# AARIA_LEARN_REVIEW=1          # default on unless 0/false
# AARIA_LEARN_APPROVAL=0        # stage writes when 1; approve via /memory approve
# Cursor model (SDK id). Default `default` = Auto. composer-2 / composer-2.5 fail for some keys.
# AARIA_MODEL=default
# AARIA_LEARN_MODEL=default     # aux agent for learn review + curator (no MCP)
# AARIA_MEMORY_CHAR_LIMIT=2200
# AARIA_USER_LEARNED_CHAR_LIMIT=1375
# AGENT_MEMORY_PATH=./MEMORY.md

# Memory curator (Hermes-style consolidation — merge/prune when memory is full)
# AARIA_CURATOR=1               # default on; set 0 to disable auto + scheduled curator
# AARIA_CURATOR_THRESHOLD=0.85  # run when MEMORY or USER learned exceeds this ratio

# Skills (Hermes-style procedural memory — skills/*.md, agentskills.io frontmatter)
# AARIA_SKILLS_PATH=./skills    # load at bootstrap; /skill <name> in TUI

# Scheduler (heartbeat + cron/interval jobs)
# AARIA_SCHEDULER=1             # default on; set 0 to disable in-process scheduler
# AARIA_JOBS_PATH=./jobs.json   # copy jobs.sample.json → jobs.json to customise
# AARIA_HEARTBEAT=1             # built-in heartbeat when jobs.json is missing
# AARIA_HEARTBEAT_EVERY=5m      # default heartbeat interval (30s, 5m, 1h, …)

# Morning brief on first WebSocket connect each day (user timezone from USER.md)
# AARIA_MORNING_BRIEF=1         # default on; set 0 to disable
# AARIA_TIMEZONE=Asia/Kolkata   # override USER.md timezone

# Voice reply (local TTS). Default character: British female Cori, calm pace.
# Applies to TUI / plasmoid / HTTP chat — not scheduler jobs or morning brief.
# TUI calls POST /voice/warmup on boot to pre-load Piper.
# AARIA_VOICE=1
# AARIA_TTS=piper
# AARIA_PIPER_MODEL=/home/you/.local/share/piper/en_GB-cori-medium.onnx
# AARIA_VOICE_MAX_CHARS=320
# AARIA_PIPER_LENGTH_SCALE=1.05
# AARIA_PIPER_SENTENCE_SILENCE=0
# AARIA_PIPER_WAV=0
# AARIA_PIPER_NOISE_SCALE=0.55
# AARIA_SPD_RATE=-20
# AARIA_SPD_LANGUAGE=en-GB
# AARIA_SPD_VOICE=
# Fleet / MQTT hub — ASTRA minions (HiveMQ default; Mosquitto optional)
# AARIA_MQTT_PROVIDER=hivemq
# AARIA_MQTT_URL=mqtts://YOUR_CLUSTER.s1.eu.hivemq.cloud:8883
# AARIA_MQTT_WS_URL=wss://YOUR_CLUSTER.s1.eu.hivemq.cloud:8884/mqtt
# AARIA_MQTT_USERNAME=mxpfaaria
# AARIA_MQTT_PASSWORD="your-password-here"
# AGENT_FLEET_PATH=./FLEET.md
